---
import Base from './Base.astro';
const { title, heading } = Astro.props;
---
<Base
  title={`${heading} | KMU-Webseiten.de`}
  description={`${heading} von kmu-webseiten.de — ein Produkt von Pixel56, Agentur für Webdesign & Online-Marketing aus Bendorf.`}
  css="/css/city.css"
  canonical={`https://kmu-webseiten.de/${title}/`}
>
  <header class="site">
    <div class="wrap">
      <a class="brand" href="/"><img src="/img/logo.png" alt="KMU-Webseiten.de Logo" /></a>
      <a class="btn btn-header" href="/#formular">Kostenlosen Entwurf sichern</a>
    </div>
  </header>

  <section>
    <div class="wrap" style="max-width: 760px;">
      <nav class="crumbs" aria-label="Brotkrumen" style="color: var(--muted); font-size: 0.82rem; margin-bottom: 1.4rem;">
        <a href="/" style="color: var(--muted); text-decoration: none;">Startseite</a> › <strong>{heading}</strong>
      </nav>
      <h1 class="display" style="font-size: clamp(1.7rem, 3vw, 2.3rem); font-weight: 800; margin-bottom: 1.6rem;">{heading}</h1>
      <div class="prose" style="margin-top: 0;">
        <slot />
      </div>
    </div>
  </section>

  <footer class="site">
    <div class="wrap">
      <a class="brand" href="/"><img src="/img/logo.png" alt="KMU-Webseiten.de" /></a>
      <nav>
        <a href="/impressum/">Impressum</a>
        <a href="/datenschutz/">Datenschutz</a>
        <a href="/agb/">AGB</a>
      </nav>
    </div>
  </footer>
</Base>
