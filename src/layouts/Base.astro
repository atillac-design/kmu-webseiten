---
const { title, description, css, canonical, ogImage = '/img/webdesign-beispiel.jpg', noindex = false } = Astro.props;
// Make-Webhook: nimmt Formular-Anfragen entgegen und leitet sie an E-Mail + MailerLite weiter.
// Öffentlich (steckt ohnehin im Browser-JS); zum Wechseln einfach hier die URL tauschen
// oder die Umgebungsvariable PUBLIC_MAKE_WEBHOOK_URL setzen.
const DEFAULT_WEBHOOK = 'https://hook.eu2.make.com/1xbi884cw1seurhhfuf844bty3egtxwy';
const webhook = import.meta.env.PUBLIC_MAKE_WEBHOOK_URL || DEFAULT_WEBHOOK;
// Onboarding-Formular (Kunden nach Zusage): eigener Make-Webhook (Szenario „KMU Onboarding").
const DEFAULT_ONBOARDING_WEBHOOK = 'https://hook.eu2.make.com/miu7jywnrhp1wkjth4194x28aq47yxmj';
const onboardingWebhook = import.meta.env.PUBLIC_ONBOARDING_WEBHOOK_URL || DEFAULT_ONBOARDING_WEBHOOK;
// Meta-Pixel (Datensatz „KMU-Webseiten"). Feuert NUR nach aktiver Einwilligung
// über den Consent-Banner (DSGVO/TDDDG). Zum Wechseln hier die ID tauschen.
const pixelId = import.meta.env.PUBLIC_META_PIXEL_ID || '881376747898001';
---
<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {canonical && <link rel="canonical" href={canonical} />}
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <link rel="icon" href="/img/logo.png" />
    <link rel="preload" href="/fonts/bricolage.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="stylesheet" href={css} />
    <style>
      #kmu-consent{position:fixed;left:0;right:0;bottom:0;z-index:9999;display:none;
        padding:.8rem 1rem;background:#12141a;color:#f4f5f7;box-shadow:0 -8px 30px rgba(0,0,0,.28);
        font-family:system-ui,-apple-system,'Segoe UI',Roboto,sans-serif}
      #kmu-consent.show{display:block}
      #kmu-consent .kc-in{max-width:1000px;margin:0 auto;display:flex;gap:.8rem 1.4rem;
        align-items:center;flex-wrap:wrap;justify-content:space-between}
      #kmu-consent p{margin:0;font-size:.86rem;line-height:1.45;flex:1 1 300px;color:#d4d7de}
      #kmu-consent p strong{color:#fff}
      #kmu-consent a{color:#8ab4ff;text-decoration:underline}
      #kmu-consent .kc-btns{display:flex;gap:.6rem;flex:0 0 auto}
      #kmu-consent button{cursor:pointer;border:0;border-radius:8px;padding:.65rem 1.2rem;
        font-size:.88rem;font-weight:600;font-family:inherit}
      #kmu-consent .kc-no{background:#2c2f38;color:#f4f5f7}
      #kmu-consent .kc-yes{background:#2f6bff;color:#fff}
      #kmu-consent .kc-no:hover{background:#3a3e49}
      #kmu-consent .kc-yes:hover{background:#1f57e6}
      @media(max-width:640px){
        #kmu-consent{padding:.55rem .7rem}
        #kmu-consent .kc-in{gap:.5rem}
        #kmu-consent p{font-size:.74rem;line-height:1.35;flex:1 1 100%}
        #kmu-consent .kc-btns{flex:1 1 100%;justify-content:stretch}
        #kmu-consent .kc-btns button{flex:1;padding:.5rem .8rem;font-size:.8rem}}
    </style>
    <script is:inline define:vars={{ webhook, onboardingWebhook, pixelId }}>window.KMU_WEBHOOK_URL = webhook; window.KMU_ONBOARDING_WEBHOOK_URL = onboardingWebhook; window.KMU_PIXEL_ID = pixelId;</script>
    <script is:inline>
      /* Herkunftsmessung ohne Cookies: Kampagnen-Parameter (utm_*) aus dem
         Anzeigen-Link merken wir uns nur für die laufende Sitzung (sessionStorage,
         wird beim Schließen des Tabs gelöscht) — damit sie das Formular auf der
         Startseite noch kennt, auch wenn der Besucher auf einer Unterseite landet. */
      (function () {
        try {
          var q = new URLSearchParams(location.search);
          var utm = {}, has = false;
          ['utm_source', 'utm_medium', 'utm_campaign', 'utm_term', 'utm_content'].forEach(function (k) {
            var v = q.get(k);
            if (v) { utm[k] = v.slice(0, 120); has = true; }
          });
          /* Auto-Kennungen der Plattformen als Fallback, falls utm_* fehlt */
          if (!utm.utm_source && q.get('gclid')) { utm.utm_source = 'google'; utm.utm_medium = utm.utm_medium || 'cpc'; has = true; }
          if (!utm.utm_source && q.get('fbclid')) { utm.utm_source = 'meta'; utm.utm_medium = utm.utm_medium || 'paid'; has = true; }
          if (has) {
            utm.landing = location.pathname;
            sessionStorage.setItem('kmu_utm', JSON.stringify(utm));
          } else if (!sessionStorage.getItem('kmu_utm') && document.referrer) {
            var ref = new URL(document.referrer);
            if (ref.hostname && ref.hostname !== location.hostname) {
              sessionStorage.setItem('kmu_utm', JSON.stringify({ ref: ref.hostname, landing: location.pathname }));
            }
          }
        } catch (e) { /* ohne Herkunft weiter — Formular funktioniert trotzdem */ }
      })();
    </script>
    <slot name="head" />
  </head>
  <body>
    <slot />

    <!-- Cookie-Consent-Banner: Meta-Pixel lädt NUR nach aktivem „Akzeptieren" (DSGVO/TDDDG) -->
    <div id="kmu-consent" role="dialog" aria-label="Cookie-Hinweis">
      <div class="kc-in">
        <p>
          <strong>Cookies für Marketing.</strong> Wir nutzen den Meta-Pixel nur mit deiner
          Einwilligung — Details in der <a href="/datenschutz/">Datenschutzerklärung</a>.
        </p>
        <div class="kc-btns">
          <button type="button" class="kc-no" id="kmuDeny">Ablehnen</button>
          <button type="button" class="kc-yes" id="kmuAllow">Akzeptieren</button>
        </div>
      </div>
    </div>

    <script is:inline>
      (function () {
        var KEY = 'kmu_consent';
        var banner = document.getElementById('kmu-consent');
        function loadPixel() {
          if (window.fbq || !window.KMU_PIXEL_ID) return;
          !function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?
            n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;
            n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;
            t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,document,
            'script','https://connect.facebook.net/en_US/fbevents.js');
          window.fbq('init', window.KMU_PIXEL_ID);
          window.fbq('track', 'PageView');
        }
        function store(v){ try { localStorage.setItem(KEY, v); } catch(e){} }
        function get(){ try { return localStorage.getItem(KEY); } catch(e){ return null; } }
        var choice = get();
        if (choice === 'granted') { window.KMU_CONSENT = true; loadPixel(); return; }
        if (choice === 'denied')  { window.KMU_CONSENT = false; return; }
        // Noch keine Wahl → Banner zeigen
        if (banner) {
          banner.classList.add('show');
          document.getElementById('kmuAllow').addEventListener('click', function () {
            store('granted'); window.KMU_CONSENT = true; banner.classList.remove('show'); loadPixel();
          });
          document.getElementById('kmuDeny').addEventListener('click', function () {
            store('denied'); window.KMU_CONSENT = false; banner.classList.remove('show');
          });
        }
      })();
    </script>
  </body>
</html>
