---
import Base from '../../layouts/Base.astro';
import { hotelsCities } from '../../data/hotels-cities.js';

export function getStaticPaths() {
  return hotelsCities.map((city) => ({ params: { slug: city.slug }, props: { city } }));
}

const { city } = Astro.props;
const title = `Webseite für Hotels & Ferienwohnungen in ${city.name} — Entwurf in 48h | KMU-Webseiten.de`;
const description = `Website für dein Hotel oder deine Ferienwohnung in ${city.name}: Direktbuchungen statt Portal-Provision, Gastgeber-Persönlichkeit, die Gäste überzeugt. Kostenloser Entwurf in 48 Stunden, ab 99 €/Monat.`;
const canonical = `https://kmu-webseiten.de/webseite-fuer-hotels/${city.slug}/`;

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: `Webseite für Hotels & Ferienwohnungen in ${city.name}`,
  description,
  url: canonical,
  provider: {
    '@type': 'ProfessionalService',
    name: 'KMU-Webseiten.de (Pixel56)',
    url: 'https://kmu-webseiten.de/',
  },
  areaServed: { '@type': 'City', name: city.name },
  audience: { '@type': 'Audience', audienceType: 'Hotels, Pensionen & Ferienwohnungen' },
});
---
<Base title={title} description={description} css="/css/city.css" canonical={canonical}>
  <script slot="head" is:inline type="application/ld+json" set:html={jsonLd} />

  <header class="site">
    <div class="wrap">
      <a class="brand" href="/"><img src="/img/logo.png" alt="KMU-Webseiten.de Logo" /></a>
      <a class="btn btn-header" href="/#formular">Kostenlosen Entwurf sichern</a>
    </div>
  </header>

  <div class="hero">
    <div class="wrap">
      <nav class="crumbs" aria-label="Brotkrumen">
        <a href="/">Startseite</a> › <a href="/webseite-fuer-hotels/" style="color:var(--hero-muted)">Webseite für Hotels</a> › <strong style="color:var(--hero-text)">{city.name}</strong>
      </nav>
      <h1 class="display">
        Jede Direktbuchung in <em>{city.name}</em> spart dir 15–20 % Provision.
      </h1>
      <p class="sub">
        Eine Website für dein Haus, die Gäste direkt bei dir buchen lässt —
        mit deiner Geschichte, deinen Zimmern und einer Anfrage ohne Umwege.
        Erster Entwurf kostenlos, in 48 Stunden.
      </p>
      <div class="cta-row">
        <a class="btn" href="/#formular">Kostenlosen Entwurf anfordern →</a>
        <span class="mini">100 % kostenlos · Antwort in 48 h</span>
      </div>
    </div>
  </div>

  <section>
    <div class="wrap">
      <div class="rv">
        <p class="eyebrow">Webseite für Hotels &amp; Ferienwohnungen {city.name}</p>
        <h2 class="display">Die Portale bringen Gäste. Deine Website macht sie zu deinen.</h2>
        <div class="prose">
          <p>Ob <strong>Hotel</strong>, <strong>Pension</strong> oder <strong>Ferienwohnung</strong> in {city.name} — Booking &amp; Co. sind gute Schaufenster, aber teure Vermieter: 15–20 % jeder Buchung bleiben dort hängen. Deine eigene Website holt dir diese Marge zurück.</p>
          <p>{city.intro}</p>
          <p>{city.pain}</p>
          <p>
            Egal ob Gäste nach <strong>„{city.searchTerms[0]}"</strong>,
            <strong>„{city.searchTerms[1]}"</strong> oder <strong>„{city.searchTerms[2]}"</strong>
            suchen — die meisten prüfen vor der Portal-Buchung die Website des Hauses.
            Überzeugt sie dort, buchen viele direkt. Gibt es keine, bleibt nur das Portal —
            samt Provision.
          </p>
        </div>
      </div>

      <div class="grid2 rv">
        <div class="g-card"><h3><span class="ic">✓</span>Direktanfrage &amp; Buchung im Fokus</h3><p>Anfrage-Formular mit Zeitraum und Zimmerwunsch oder Anbindung deiner Buchungsstrecke — jeder direkte Gast spart dir bares Geld.</p></div>
        <div class="g-card"><h3><span class="ic">✓</span>Dein Haus, deine Geschichte</h3><p>Auf Portalen bist du eine Zeile von vielen — auf deiner Website bist du Gastgeber mit Gesicht, Lage und Charakter. Genau das bindet Stammgäste.</p></div>
        <div class="g-card"><h3><span class="ic">✓</span>Zimmer &amp; Region groß in Szene</h3><p>Große Bilder, Ausstattung, Ausflugstipps: Wir verkaufen nicht nur das Bett, sondern den ganzen Aufenthalt in {city.name}.</p></div>
        <div class="g-card"><h3><span class="ic">✓</span>Gefunden von planenden Gästen</h3><p>Lokal optimiert für die Suchen deiner Zielgäste — vom Wanderer bis zum Geschäftsreisenden, in Deutsch verständlich für internationale Gäste.</p></div>
      </div>

      <div class="localbox rv">
        <span class="pin">🛎️ Für Gastgeber, die am Empfang gebraucht werden</span>
        <h3 class="display">Du kümmerst dich um deine Gäste. Wir um deine Buchungslage.</h3>
        <p>Du schickst uns Bilder, Zimmertypen und ein paar Worte zu deinem Haus — wir liefern in 48 Stunden einen Entwurf, der Lust auf deine Region macht und die Direktanfrage zum einfachsten Weg. Saisonzeiten und Angebote pflegen wir danach laufend ein.</p>
      </div>
    </div>
  </section>

  <section class="tight">
    <div class="wrap">
      <div class="rv">
        <p class="eyebrow">So einfach geht's</p>
        <h2 class="display">In 3 Schritten zur neuen Website für dein Haus in {city.name}.</h2>
      </div>
      <div class="steps-inline rv">
        <div class="s-card"><span class="num">SCHRITT 01</span><h3>60 Sekunden Formular</h3><p>Haus, Zimmerzahl, Stadt — mehr brauchen wir nicht, um loszulegen.</p></div>
        <div class="s-card"><span class="num">SCHRITT 02</span><h3>Entwurf in 48 Stunden</h3><p>Du siehst einen echten Entwurf deiner neuen Website. Kostenlos.</p></div>
        <div class="s-card"><span class="num">SCHRITT 03</span><h3>Live in wenigen Tagen</h3><p>Gefällt er dir, wählst du dein Paket ab 99 €/Monat — 0 € Startkosten.</p></div>
      </div>
    </div>
  </section>

  <section class="tight">
    <div class="wrap">
      <div class="rv">
        <p class="eyebrow">Häufige Fragen von Gastgebern</p>
        <h2 class="display">Kurz beantwortet.</h2>
        <div class="faq">
          <details>
            <summary>Soll ich Booking &amp; Co. dann ganz verlassen?</summary>
            <p>Nein — die Portale bleiben ein starker Kanal für neue Gäste. Die Strategie: Portale für die Reichweite, deine Website für Stammgäste, Anfragen außerhalb der Portale und alle, die vor der Buchung recherchieren. Jede so gewonnene Direktbuchung ist Provision, die bei dir bleibt.</p>
          </details>
          <details>
            <summary>Kann ich mein Channel-Manager- oder Buchungssystem einbinden?</summary>
            <p>Ja — ob DIRS21, Smoobu, Beds24 oder ein anderes System: Wir verlinken oder betten deine Buchungsstrecke ein, damit Verfügbarkeiten und Preise immer stimmen.</p>
          </details>
          <details>
            <summary>Reicht nicht mein Eintrag beim Portal plus Google Maps?</summary>
            <p>Für Sichtbarkeit ja, für Marge nein: Ohne eigene Website gibt es keinen Weg an der Provision vorbei — und keinen Ort, an dem du Stammgäste, Gutscheine oder Arrangements direkt vermarkten kannst.</p>
          </details>
          <details>
            <summary>Was kostet das?</summary>
            <p>Feste Pakete ab 99 € im Monat mit 0 € Startkosten — alle Details findest du auf der <a href="/#preise">Startseite unter Preise</a>. Vorher siehst du immer erst deinen kostenlosen Entwurf. Zum Vergleich: Das ist weniger, als die Portal-Provision einer einzigen Wochenbuchung kostet.</p>
          </details>
        </div>
      </div>
    </div>
  </section>

  <div class="cta-band" id="cta">
    <div class="wrap rv">
      <h2 class="display">Sichere dir deinen kostenlosen Website-Entwurf für dein Haus in {city.name}.</h2>
      <p>60 Sekunden Formular — in 48 Stunden siehst du, wie dein neuer Auftritt aussehen könnte. Kostenlos und unverbindlich.</p>
      <a class="btn big" href="/#formular">Jetzt kostenlosen Entwurf anfordern →</a>
    </div>
  </div>

  <footer class="site">
    <div class="wrap">
      <a class="brand" href="/"><img src="/img/logo.png" alt="KMU-Webseiten.de" /></a>
      <nav>
        <a href="/branchen/">Branchen</a>
        <a href="/impressum/">Impressum</a>
        <a href="/datenschutz/">Datenschutz</a>
        <a href="/agb/">AGB</a>
      </nav>
    </div>
  </footer>

  <script is:inline src="/js/reveal.js" defer></script>
</Base>
