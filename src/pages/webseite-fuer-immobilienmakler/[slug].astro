---
import Base from '../../layouts/Base.astro';
import { immoCities } from '../../data/immo-cities.js';

export function getStaticPaths() {
  return immoCities.map((city) => ({ params: { slug: city.slug }, props: { city } }));
}

const { city } = Astro.props;
const title = `Webseite für Immobilienmakler in ${city.name} — Entwurf in 48h | KMU-Webseiten.de`;
const description = `Website für dein Maklerbüro in ${city.name} erstellen lassen: seriöser Auftritt, der Verkäufer überzeugt und Mandate bringt. Kostenloser Entwurf in 48 Stunden, Pakete ab 99 €/Monat.`;
const canonical = `https://kmu-webseiten.de/webseite-fuer-immobilienmakler/${city.slug}/`;

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: `Webseite für Immobilienmakler in ${city.name}`,
  description,
  url: canonical,
  provider: {
    '@type': 'ProfessionalService',
    name: 'KMU-Webseiten.de (Pixel56)',
    url: 'https://kmu-webseiten.de/',
  },
  areaServed: { '@type': 'City', name: city.name },
  audience: { '@type': 'Audience', audienceType: 'Immobilienmakler' },
});
---
<Base title={title} description={description} css="/css/city.css" canonical={canonical}>
  <script slot="head" is:inline type="application/ld+json" set:html={jsonLd} />

  <header class="site">
    <div class="wrap">
      <a class="brand" href="/"><img src="/img/logo.png" alt="KMU-Webseiten.de Logo" /></a>
      <a class="btn btn-header" href="/#formular">Kostenlosen Entwurf sichern</a>
    </div>
  </header>

  <div class="hero">
    <div class="wrap">
      <nav class="crumbs" aria-label="Brotkrumen">
        <a href="/">Startseite</a> › <strong style="color:var(--hero-text)">Webseite für Immobilienmakler in {city.name}</strong>
      </nav>
      <h1 class="display">
        Verkäufer wählen ihren Makler online aus. Deine Website in <em>{city.name}</em> entscheidet, ob sie dich wählen.
      </h1>
      <p class="sub">
        Speziell für Immobilienmakler in {city.name}: ein seriöser, hochwertiger Auftritt, der
        Eigentümer überzeugt und dir die lukrativen Verkaufsmandate bringt. Erster Entwurf kostenlos,
        in 48 Stunden.
      </p>
      <div class="cta-row">
        <a class="btn" href="/#formular">Kostenlosen Entwurf anfordern →</a>
        <span class="mini">100 % kostenlos · Antwort in 48 h</span>
      </div>
    </div>
  </div>

  <section>
    <div class="wrap">
      <div class="rv">
        <p class="eyebrow">Webseite für Immobilienmakler {city.name}</p>
        <h2 class="display">Dein Geschäft ist nicht der Käufer. Es ist der Verkäufer — und der prüft dich genau.</h2>
        <div class="prose">
          <p>Ob <strong>Webseite</strong>, <strong>Homepage</strong> oder <strong>Webdesign für Makler</strong> in {city.name} — bei den Werten, um die es in der Immobilie geht, zählt vor allem eines: ein Auftritt, der Eigentümern das Vertrauen gibt, dir ihr Objekt anzuvertrauen. Genau den schaffen wir.</p>
          <p>{city.intro}</p>
          <p>{city.pain}</p>
          <p>
            Ob nach <strong>„{city.searchTerms[0]}"</strong>, <strong>„{city.searchTerms[1]}"</strong>
            oder <strong>„{city.searchTerms[2]}"</strong> gesucht wird — wer in {city.name} nicht
            professionell und vertrauenswürdig auftritt, bekommt die wertvollen Mandate gar nicht erst.
          </p>
        </div>
      </div>

      <div class="grid2 rv">
        <div class="g-card"><h3><span class="ic">✓</span>Seriosität, die Mandate bringt</h3><p>Ein hochwertiger Auftritt, der Eigentümern signalisiert: Diesem Makler kann ich mein Objekt anvertrauen.</p></div>
        <div class="g-card"><h3><span class="ic">✓</span>Verkäufer gezielt ansprechen</h3><p>Eigene Bereiche für Eigentümer — kostenlose Immobilienbewertung, Verkaufsablauf, Referenzen — damit aus Besuchern Mandate werden.</p></div>
        <div class="g-card"><h3><span class="ic">✓</span>Objekte, die überzeugen</h3><p>Deine Angebote klar und ansprechend präsentiert — auf Wunsch verbunden mit deiner Maklersoftware.</p></div>
        <div class="g-card"><h3><span class="ic">✓</span>Lokal gefunden werden</h3><p>Optimiert auf „Immobilienmakler {city.name}" &amp; „Haus verkaufen {city.name}", mit gepflegtem Google-Profil und echten Bewertungen.</p></div>
      </div>

      <div class="localbox rv">
        <span class="pin">🏡 Für Makler, die auf Substanz statt Sprüche setzen</span>
        <h3 class="display">Wir geben deinem Büro den Auftritt, den deine Mandate wert sind.</h3>
        <p>Du schickst uns ein paar Eckdaten zu dir und deinem Markt — wir gestalten daraus in 48 Stunden einen Entwurf, der Kompetenz und Vertrauen ausstrahlt. Ein Auftritt, mit dem du beim Eigentümer-Termin punktest, statt dich für die alte Website zu entschuldigen.</p>
      </div>
    </div>
  </section>

  <section class="tight">
    <div class="wrap">
      <div class="rv">
        <p class="eyebrow">So einfach geht's</p>
        <h2 class="display">In 3 Schritten zur neuen Website für dein Maklerbüro in {city.name}.</h2>
      </div>
      <div class="steps-inline rv">
        <div class="s-card"><span class="num">SCHRITT 01</span><h3>60 Sekunden Formular</h3><p>Büro, Schwerpunkt, Stadt — mehr brauchen wir nicht, um loszulegen.</p></div>
        <div class="s-card"><span class="num">SCHRITT 02</span><h3>Entwurf in 48 Stunden</h3><p>Du bekommst einen echten Entwurf deiner neuen Website. Kostenlos.</p></div>
        <div class="s-card"><span class="num">SCHRITT 03</span><h3>Live in wenigen Tagen</h3><p>Gefällt er dir, wählst du dein Paket ab 99 €/Monat — 0 € Startkosten.</p></div>
      </div>
    </div>
  </section>

  <section class="tight">
    <div class="wrap">
      <div class="rv">
        <p class="eyebrow">Häufige Fragen von Maklern</p>
        <h2 class="display">Kurz beantwortet.</h2>
        <div class="faq">
          <details>
            <summary>Hilft die Website wirklich, mehr Verkaufsmandate zu bekommen?</summary>
            <p>Ja — genau darauf richten wir sie aus. Eigentümer vergleichen Makler online, bevor sie anrufen. Ein seriöser Auftritt mit Bereichen wie „kostenlose Immobilienbewertung" und „so läuft der Verkauf" holt gezielt Verkäufer ab, statt nur Objekte zu zeigen.</p>
          </details>
          <details>
            <summary>Können meine Objekte automatisch angezeigt werden?</summary>
            <p>Auf Wunsch verbinden wir die Website mit deiner Maklersoftware, sodass Angebote automatisch erscheinen. Alternativ pflegen wir ausgewählte Referenzobjekte ein — je nachdem, was für dich passt.</p>
          </details>
          <details>
            <summary>Wie hebe ich mich von anderen Maklern ab?</summary>
            <p>Durch Klarheit und Seriosität statt austauschbarer Floskeln. Wir arbeiten deine Positionierung heraus — für wen du arbeitest, was dich auszeichnet — und bringen sie in einen Auftritt, der Eigentümer überzeugt.</p>
          </details>
          <details>
            <summary>Was kostet das?</summary>
            <p>Feste Pakete ab 99 € im Monat mit 0 € Startkosten — alle Details findest du auf der <a href="/#preise">Startseite unter Preise</a>. Vorher siehst du immer erst deinen kostenlosen Entwurf.</p>
          </details>
        </div>
      </div>
    </div>
  </section>

  <div class="cta-band" id="cta">
    <div class="wrap rv">
      <h2 class="display">Sichere dir deinen kostenlosen Website-Entwurf für dein Maklerbüro in {city.name}.</h2>
      <p>60 Sekunden Formular — in 48 Stunden siehst du, wie deine neue Website aussehen könnte. Kostenlos und unverbindlich.</p>
      <a class="btn big" href="/#formular">Jetzt kostenlosen Entwurf anfordern →</a>
    </div>
  </div>

  <footer class="site">
    <div class="wrap">
      <a class="brand" href="/"><img src="/img/logo.png" alt="KMU-Webseiten.de" /></a>
      <nav>
        <a href="/impressum/">Impressum</a>
        <a href="/datenschutz/">Datenschutz</a>
        <a href="/agb/">AGB</a>
      </nav>
    </div>
  </footer>

  <script is:inline src="/js/reveal.js" defer></script>
</Base>
