---
import Base from '../../layouts/Base.astro';
import { galabauCities } from '../../data/galabau-cities.js';

export function getStaticPaths() {
  return galabauCities.map((city) => ({ params: { slug: city.slug }, props: { city } }));
}

const { city } = Astro.props;
const title = `Webseite für Garten- & Landschaftsbau in ${city.name} — Entwurf in 48h | KMU-Webseiten.de`;
const description = `Website für deinen Galabau-Betrieb in ${city.name}: Projektgalerie, die Gartenträume verkauft, Anfragen für Gestaltung & Pflegeverträge. Kostenloser Entwurf in 48 Stunden, ab 99 €/Monat.`;
const canonical = `https://kmu-webseiten.de/webseite-fuer-galabau/${city.slug}/`;

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: `Webseite für Garten- und Landschaftsbau in ${city.name}`,
  description,
  url: canonical,
  provider: {
    '@type': 'ProfessionalService',
    name: 'KMU-Webseiten.de (Pixel56)',
    url: 'https://kmu-webseiten.de/',
  },
  areaServed: { '@type': 'City', name: city.name },
  audience: { '@type': 'Audience', audienceType: 'Garten- & Landschaftsbau' },
});
---
<Base title={title} description={description} css="/css/city.css" canonical={canonical}>
  <script slot="head" is:inline type="application/ld+json" set:html={jsonLd} />

  <header class="site">
    <div class="wrap">
      <a class="brand" href="/"><img src="/img/logo.png" alt="KMU-Webseiten.de Logo" /></a>
      <a class="btn btn-header" href="/#formular">Kostenlosen Entwurf sichern</a>
    </div>
  </header>

  <div class="hero">
    <div class="wrap">
      <nav class="crumbs" aria-label="Brotkrumen">
        <a href="/">Startseite</a> › <a href="/webseite-fuer-galabau/" style="color:var(--hero-muted)">Webseite für Galabau</a> › <strong style="color:var(--hero-text)">{city.name}</strong>
      </nav>
      <h1 class="display">
        Gartenträume in <em>{city.name}</em> beginnen mit Bildern — deinen Bildern.
      </h1>
      <p class="sub">
        Eine Website für deinen Garten- und Landschaftsbau, die deine Projekte
        wirken lässt — und aus Gartenträumern zahlende Auftraggeber macht.
        Erster Entwurf kostenlos, in 48 Stunden.
      </p>
      <div class="cta-row">
        <a class="btn" href="/#formular">Kostenlosen Entwurf anfordern →</a>
        <span class="mini">100 % kostenlos · Antwort in 48 h</span>
      </div>
    </div>
  </div>

  <section>
    <div class="wrap">
      <div class="rv">
        <p class="eyebrow">Webseite für Garten- &amp; Landschaftsbau {city.name}</p>
        <h2 class="display">Deine Arbeit sieht man. Deine Website sollte man auch sehen.</h2>
        <div class="prose">
          <p>Ob <strong>Gartengestaltung</strong>, <strong>Pflasterarbeiten</strong> oder <strong>Pflegeverträge</strong> in {city.name} — kein Gewerk verkauft sich so stark über Bilder wie der Galabau. Deine fertigen Gärten sind dein bestes Marketing. Man muss sie nur finden.</p>
          <p>{city.intro}</p>
          <p>{city.pain}</p>
          <p>
            Egal ob nach <strong>„{city.searchTerms[0]}"</strong>,
            <strong>„{city.searchTerms[1]}"</strong> oder <strong>„{city.searchTerms[2]}"</strong>
            gesucht wird — Gartenprojekte sind Vertrauens- und Geschmackssache: Beauftragt
            wird der Betrieb, dessen Referenzen begeistern. Ohne Online-Galerie findet
            diese Begeisterung nie statt.
          </p>
        </div>
      </div>

      <div class="grid2 rv">
        <div class="g-card"><h3><span class="ic">✓</span>Projektgalerie mit Wow-Effekt</h3><p>Vorher/Nachher, große Bilder, kurze Projektbeschreibungen — deine schönsten Gärten verkaufen die nächsten.</p></div>
        <div class="g-card"><h3><span class="ic">✓</span>Anfragen für Projekt &amp; Pflege</h3><p>Gestaltungsanfrage für Private, Pflegevertrag-Anfrage für Firmen und Verwaltungen — beide Umsatzquellen klar getrennt bedient.</p></div>
        <div class="g-card"><h3><span class="ic">✓</span>Leistungen einzeln auffindbar</h3><p>Pflaster, Zäune, Teich, Bewässerung, Baumpflege: Jede Leistung bekommt ihren Platz — und wird bei Google einzeln gefunden.</p></div>
        <div class="g-card"><h3><span class="ic">✓</span>Saisonale Themen im Blick</h3><p>Frühjahrs-Check, Herbstschnitt, Bewässerung im Sommer — wir halten deine Seite im Rhythmus deiner Saison aktuell.</p></div>
      </div>

      <div class="localbox rv">
        <span class="pin">🌿 Für Betriebe, die draußen gebraucht werden</span>
        <h3 class="display">Du baust Gärten. Wir bauen deine Anfragen-Maschine.</h3>
        <p>Du schickst uns Fotos deiner besten Projekte und deine Leistungen — wir liefern in 48 Stunden einen Entwurf, der deine Arbeit so hochwertig zeigt, wie sie ist. Neue Projekte pflegen wir laufend in die Galerie ein.</p>
      </div>
    </div>
  </section>

  <section class="tight">
    <div class="wrap">
      <div class="rv">
        <p class="eyebrow">So einfach geht's</p>
        <h2 class="display">In 3 Schritten zur neuen Website für deinen Betrieb in {city.name}.</h2>
      </div>
      <div class="steps-inline rv">
        <div class="s-card"><span class="num">SCHRITT 01</span><h3>60 Sekunden Formular</h3><p>Betrieb, Leistungen, Stadt — mehr brauchen wir nicht, um loszulegen.</p></div>
        <div class="s-card"><span class="num">SCHRITT 02</span><h3>Entwurf in 48 Stunden</h3><p>Du siehst einen echten Entwurf deiner neuen Website. Kostenlos.</p></div>
        <div class="s-card"><span class="num">SCHRITT 03</span><h3>Live in wenigen Tagen</h3><p>Gefällt er dir, wählst du dein Paket ab 99 €/Monat — 0 € Startkosten.</p></div>
      </div>
    </div>
  </section>

  <section class="tight">
    <div class="wrap">
      <div class="rv">
        <p class="eyebrow">Häufige Fragen aus dem Galabau</p>
        <h2 class="display">Kurz beantwortet.</h2>
        <div class="faq">
          <details>
            <summary>Unsere Aufträge kommen über Empfehlungen — brauchen wir das wirklich?</summary>
            <p>Empfehlungen bringen dich ins Gespräch, die Website macht den Sack zu: Fast jeder Empfohlene schaut vor der Anfrage online nach. Und die großen Gestaltungsprojekte von Zugezogenen und Neubauherren — die keinen kennen, der dich kennt — kommen ausschließlich über Google.</p>
          </details>
          <details>
            <summary>Wir haben kaum gute Fotos unserer Projekte — was nun?</summary>
            <p>Ab sofort nach jedem Projekt kurz mit dem Handy dokumentieren (wir sagen dir, wie) — und für den Start reichen oft schon eine Handvoll guter Aufnahmen plus Detailbilder. Die Galerie wächst dann mit jedem Auftrag mit; wir pflegen neue Bilder laufend ein.</p>
          </details>
          <details>
            <summary>Können wir Pflegeverträge für Firmen gezielt bewerben?</summary>
            <p>Ja — mit einem eigenen Bereich für Gewerbe- und Verwaltungskunden: Referenzobjekte, Leistungsumfang, Ansprechpartner. Diese planbaren Daueraufträge sind das wirtschaftliche Fundament, und genau so behandeln wir sie auf der Website.</p>
          </details>
          <details>
            <summary>Was kostet das?</summary>
            <p>Feste Pakete ab 99 € im Monat mit 0 € Startkosten — alle Details findest du auf der <a href="/#preise">Startseite unter Preise</a>. Vorher siehst du immer erst deinen kostenlosen Entwurf.</p>
          </details>
        </div>
      </div>
    </div>
  </section>

  <div class="cta-band" id="cta">
    <div class="wrap rv">
      <h2 class="display">Sichere dir deinen kostenlosen Website-Entwurf für deinen Galabau-Betrieb in {city.name}.</h2>
      <p>60 Sekunden Formular — in 48 Stunden siehst du, wie deine neue Website aussehen könnte. Kostenlos und unverbindlich.</p>
      <a class="btn big" href="/#formular">Jetzt kostenlosen Entwurf anfordern →</a>
    </div>
  </div>

  <footer class="site">
    <div class="wrap">
      <a class="brand" href="/"><img src="/img/logo.png" alt="KMU-Webseiten.de" /></a>
      <nav>
        <a href="/branchen/">Branchen</a>
        <a href="/impressum/">Impressum</a>
        <a href="/datenschutz/">Datenschutz</a>
        <a href="/agb/">AGB</a>
      </nav>
    </div>
  </footer>

  <script is:inline src="/js/reveal.js" defer></script>
</Base>
