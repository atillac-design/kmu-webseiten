---
import Base from '../../layouts/Base.astro';
import { fotografenCities } from '../../data/fotografen-cities.js';

export function getStaticPaths() {
  return fotografenCities.map((city) => ({ params: { slug: city.slug }, props: { city } }));
}

const { city } = Astro.props;
const title = `Homepage & Website für Fotografen in ${city.name} — Entwurf in 48h | KMU-Webseiten.de`;
const description = `Website für Fotografen in ${city.name} erstellen lassen: Portfolio, das verkauft, blitzschnelle Galerien, Buchungsanfragen statt Instagram-Likes. Kostenloser Entwurf in 48 Stunden, Pakete ab 99 €/Monat.`;
const canonical = `https://kmu-webseiten.de/homepage-fuer-fotografen/${city.slug}/`;

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: `Homepage für Fotografen in ${city.name}`,
  description,
  url: canonical,
  provider: {
    '@type': 'ProfessionalService',
    name: 'KMU-Webseiten.de (Pixel56)',
    url: 'https://kmu-webseiten.de/',
  },
  areaServed: { '@type': 'City', name: city.name },
  audience: { '@type': 'Audience', audienceType: 'Fotografen' },
});
---
<Base title={title} description={description} css="/css/city.css" canonical={canonical}>
  <script slot="head" is:inline type="application/ld+json" set:html={jsonLd} />

  <header class="site">
    <div class="wrap">
      <a class="brand" href="/"><img src="/img/logo.png" alt="KMU-Webseiten.de Logo" /></a>
      <a class="btn btn-header" href="/#formular">Kostenlosen Entwurf sichern</a>
    </div>
  </header>

  <div class="hero">
    <div class="wrap">
      <nav class="crumbs" aria-label="Brotkrumen">
        <a href="/">Startseite</a> › <a href="/homepage-fuer-fotografen/" style="color:var(--hero-muted)">Homepage für Fotografen</a> › <strong style="color:var(--hero-text)">{city.name}</strong>
      </nav>
      <h1 class="display">
        Deine Bilder sind stark. Deine Website in <em>{city.name}</em> sollte es auch sein.
      </h1>
      <p class="sub">
        Eine Portfolio-Website, die deine Arbeit verkauft statt sie nur zu zeigen —
        blitzschnelle Galerien, klare Buchungsanfrage, gefunden bei Google.
        Erster Entwurf kostenlos, in 48 Stunden.
      </p>
      <div class="cta-row">
        <a class="btn" href="/#formular">Kostenlosen Entwurf anfordern →</a>
        <span class="mini">100 % kostenlos · Antwort in 48 h</span>
      </div>
    </div>
  </div>

  <section>
    <div class="wrap">
      <div class="rv">
        <p class="eyebrow">Homepage &amp; Website für Fotografen {city.name}</p>
        <h2 class="display">Instagram bringt Likes. Deine Website bringt Buchungen.</h2>
        <div class="prose">
          <p>Ob <strong>Portfolio-Website</strong> oder <strong>Homepage für dein Fotostudio</strong> in {city.name} — dein Auftritt muss zwei Dinge können: deine Bildsprache perfekt zur Geltung bringen und aus Besuchern Anfragen machen. Genau dafür bauen wir sie.</p>
          <p>{city.intro}</p>
          <p>{city.pain}</p>
          <p>
            Egal ob Kunden nach <strong>„{city.searchTerms[0]}"</strong>,
            <strong>„{city.searchTerms[1]}"</strong> oder <strong>„{city.searchTerms[2]}"</strong>
            suchen — gebucht wird, wer gefunden wird und dessen Portfolio in Sekunden lädt.
            Eine träge Galerie oder ein reiner Instagram-Auftritt kostet dich genau die
            Aufträge, für die du fotografierst.
          </p>
        </div>
      </div>

      <div class="grid2 rv">
        <div class="g-card"><h3><span class="ic">✓</span>Galerien, die in Sekunden laden</h3><p>Deine Bilder in voller Wirkung, technisch perfekt optimiert — keine Ladebalken, kein Qualitätsverlust, auch mobil.</p></div>
        <div class="g-card"><h3><span class="ic">✓</span>Design, das deinen Bildern dient</h3><p>Zurückhaltendes Layout, große Flächen, deine Bildsprache im Mittelpunkt — statt Templates, die mit deinen Fotos konkurrieren.</p></div>
        <div class="g-card"><h3><span class="ic">✓</span>Buchungsanfrage statt DM-Chaos</h3><p>Paket, Wunschtermin, Kontakt — strukturierte Anfragen statt verstreuter Instagram-Nachrichten, die untergehen.</p></div>
        <div class="g-card"><h3><span class="ic">✓</span>Gefunden in deiner Nische</h3><p>Hochzeit, Business, Produkt: Wir optimieren deine Seite auf die Suchbegriffe, mit denen deine Wunschkunden in {city.name} suchen.</p></div>
      </div>

      <div class="localbox rv">
        <span class="pin">📸 Für Fotografen, die lieber hinter der Kamera stehen</span>
        <h3 class="display">Du machst die Bilder. Wir machen daraus deinen Auftritt.</h3>
        <p>Du schickst uns eine Auswahl deiner besten Arbeiten und sagst uns, welche Aufträge du willst — wir liefern in 48 Stunden einen Entwurf, der genau diese Kunden anspricht. Portfolio-Struktur, Texte und Suchmaschinen-Optimierung inklusive.</p>
      </div>
    </div>
  </section>

  <section class="tight">
    <div class="wrap">
      <div class="rv">
        <p class="eyebrow">So einfach geht's</p>
        <h2 class="display">In 3 Schritten zur neuen Fotografen-Website in {city.name}.</h2>
      </div>
      <div class="steps-inline rv">
        <div class="s-card"><span class="num">SCHRITT 01</span><h3>60 Sekunden Formular</h3><p>Deine Fotografie-Nische, dein Name, deine Stadt — mehr brauchen wir nicht.</p></div>
        <div class="s-card"><span class="num">SCHRITT 02</span><h3>Entwurf in 48 Stunden</h3><p>Du siehst einen echten Entwurf deiner neuen Portfolio-Website. Kostenlos.</p></div>
        <div class="s-card"><span class="num">SCHRITT 03</span><h3>Live in wenigen Tagen</h3><p>Gefällt er dir, wählst du dein Paket ab 99 €/Monat — 0 € Startkosten.</p></div>
      </div>
    </div>
  </section>

  <section class="tight">
    <div class="wrap">
      <div class="rv">
        <p class="eyebrow">Häufige Fragen von Fotografen</p>
        <h2 class="display">Kurz beantwortet.</h2>
        <div class="faq">
          <details>
            <summary>Kann ich meine Galerien später selbst aktualisieren?</summary>
            <p>Du schickst uns neue Bilder einfach zu — wir pflegen sie ein, das ist in deinem Paket enthalten. So bleibt die Seite technisch perfekt optimiert (Ladezeit!), ohne dass du dich mit Bildkomprimierung beschäftigen musst.</p>
          </details>
          <details>
            <summary>Werden meine Bilder komprimiert oder in schlechterer Qualität gezeigt?</summary>
            <p>Wir optimieren technisch (moderne Formate, passende Auflösungen pro Gerät), ohne sichtbaren Qualitätsverlust. Deine Bilder laden schnell und sehen trotzdem so aus, wie du sie abgeliefert hast.</p>
          </details>
          <details>
            <summary>Ich habe schon Instagram — brauche ich überhaupt eine Website?</summary>
            <p>Instagram ist dein Schaufenster, die Website dein Geschäft: Nur dort bestimmst du Reihenfolge, Wirkung und den Weg zur Anfrage — und nur die Website wird bei Google gefunden, wenn jemand konkret einen Fotografen sucht. Beides zusammen funktioniert am besten; wir verlinken deinen Feed selbstverständlich.</p>
          </details>
          <details>
            <summary>Was kostet das?</summary>
            <p>Feste Pakete ab 99 € im Monat mit 0 € Startkosten — alle Details findest du auf der <a href="/#preise">Startseite unter Preise</a>. Vorher siehst du immer erst deinen kostenlosen Entwurf.</p>
          </details>
        </div>
      </div>
    </div>
  </section>

  <div class="cta-band" id="cta">
    <div class="wrap rv">
      <h2 class="display">Sichere dir deinen kostenlosen Website-Entwurf für deine Fotografie in {city.name}.</h2>
      <p>60 Sekunden Formular — in 48 Stunden siehst du, wie dein neues Portfolio aussehen könnte. Kostenlos und unverbindlich.</p>
      <a class="btn big" href="/#formular">Jetzt kostenlosen Entwurf anfordern →</a>
    </div>
  </div>

  <footer class="site">
    <div class="wrap">
      <a class="brand" href="/"><img src="/img/logo.png" alt="KMU-Webseiten.de" /></a>
      <nav>
        <a href="/branchen/">Branchen</a>
        <a href="/impressum/">Impressum</a>
        <a href="/datenschutz/">Datenschutz</a>
        <a href="/agb/">AGB</a>
      </nav>
    </div>
  </footer>

  <script is:inline src="/js/reveal.js" defer></script>
</Base>
