---
import Base from '../../layouts/Base.astro';
import { fitnessCities } from '../../data/fitness-cities.js';

export function getStaticPaths() {
  return fitnessCities.map((city) => ({ params: { slug: city.slug }, props: { city } }));
}

const { city } = Astro.props;
const title = `Webseite für Fitnessstudios in ${city.name} — Entwurf in 48h | KMU-Webseiten.de`;
const description = `Website für dein Fitnessstudio in ${city.name} erstellen lassen: Probetraining-Anfragen statt nur Besucher, Kursplan & Preise klar präsentiert. Kostenloser Entwurf in 48 Stunden, Pakete ab 99 €/Monat.`;
const canonical = `https://kmu-webseiten.de/webseite-fuer-fitnessstudios/${city.slug}/`;

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: `Webseite für Fitnessstudios in ${city.name}`,
  description,
  url: canonical,
  provider: {
    '@type': 'ProfessionalService',
    name: 'KMU-Webseiten.de (Pixel56)',
    url: 'https://kmu-webseiten.de/',
  },
  areaServed: { '@type': 'City', name: city.name },
  audience: { '@type': 'Audience', audienceType: 'Fitnessstudios' },
});
---
<Base title={title} description={description} css="/css/city.css" canonical={canonical}>
  <script slot="head" is:inline type="application/ld+json" set:html={jsonLd} />

  <header class="site">
    <div class="wrap">
      <a class="brand" href="/"><img src="/img/logo.png" alt="KMU-Webseiten.de Logo" /></a>
      <a class="btn btn-header" href="/#formular">Kostenlosen Entwurf sichern</a>
    </div>
  </header>

  <div class="hero">
    <div class="wrap">
      <nav class="crumbs" aria-label="Brotkrumen">
        <a href="/">Startseite</a> › <a href="/webseite-fuer-fitnessstudios/" style="color:var(--hero-muted)">Webseite für Fitnessstudios</a> › <strong style="color:var(--hero-text)">{city.name}</strong>
      </nav>
      <h1 class="display">
        Neue Mitglieder in <em>{city.name}</em> googeln zuerst — und trainieren dann.
      </h1>
      <p class="sub">
        Eine Website für dein Studio, die aus Interessenten Probetrainings macht —
        mit Kursplan, echten Bildern und einem Anmelde-Button, der funktioniert.
        Erster Entwurf kostenlos, in 48 Stunden.
      </p>
      <div class="cta-row">
        <a class="btn" href="/#formular">Kostenlosen Entwurf anfordern →</a>
        <span class="mini">100 % kostenlos · Antwort in 48 h</span>
      </div>
    </div>
  </div>

  <section>
    <div class="wrap">
      <div class="rv">
        <p class="eyebrow">Webseite für Fitnessstudios {city.name}</p>
        <h2 class="display">Dein Studio ist stark. Zeig es dort, wo Mitglieder suchen.</h2>
        <div class="prose">
          <p>Ob <strong>klassisches Gym</strong>, <strong>Boutique-Studio</strong> oder <strong>Personal Training</strong> in {city.name} — die Entscheidung für ein Probetraining fällt online. Deine Website muss Atmosphäre transportieren und den Weg zur Anmeldung radikal einfach machen.</p>
          <p>{city.intro}</p>
          <p>{city.pain}</p>
          <p>
            Egal ob Interessenten nach <strong>„{city.searchTerms[0]}"</strong>,
            <strong>„{city.searchTerms[1]}"</strong> oder <strong>„{city.searchTerms[2]}"</strong>
            suchen — sie vergleichen zwei, drei Studios und melden sich dort, wo Angebot,
            Preise und Einstieg sofort klar sind. Wer das nicht bietet, füllt die Kurse
            der Konkurrenz.
          </p>
        </div>
      </div>

      <div class="grid2 rv">
        <div class="g-card"><h3><span class="ic">✓</span>Probetraining als klares Ziel</h3><p>Jede Seite führt zum Probetraining-Button — das ist die Conversion, von der dein Studio lebt.</p></div>
        <div class="g-card"><h3><span class="ic">✓</span>Kursplan &amp; Preise übersichtlich</h3><p>Die zwei meistgesuchten Infos, sauber präsentiert und einfach aktuell zu halten — keine PDF-Downloads von 2022.</p></div>
        <div class="g-card"><h3><span class="ic">✓</span>Echte Studio-Atmosphäre</h3><p>Deine Räume, deine Trainer, deine Community — echte Fotos schlagen jedes Stock-Sixpack, weil sie zeigen, wie es sich bei dir anfühlt.</p></div>
        <div class="g-card"><h3><span class="ic">✓</span>Lokal gefunden werden</h3><p>Stadtteil, Trainingsziel, Angebot: Wir optimieren auf die Suchen, mit denen Mitglieder in {city.name} wirklich suchen.</p></div>
      </div>

      <div class="localbox rv">
        <span class="pin">💪 Für Studios, die auf der Fläche gebraucht werden</span>
        <h3 class="display">Du kümmerst dich um deine Mitglieder. Wir um deine Website.</h3>
        <p>Du gibst uns Kursplan, Preise und ein paar Eckdaten — wir liefern in 48 Stunden einen Entwurf, der dein Studio so energiegeladen zeigt, wie es ist. Danach halten wir die Seite aktuell, während du auf der Trainingsfläche stehst.</p>
      </div>
    </div>
  </section>

  <section class="tight">
    <div class="wrap">
      <div class="rv">
        <p class="eyebrow">So einfach geht's</p>
        <h2 class="display">In 3 Schritten zur neuen Studio-Website in {city.name}.</h2>
      </div>
      <div class="steps-inline rv">
        <div class="s-card"><span class="num">SCHRITT 01</span><h3>60 Sekunden Formular</h3><p>Studio-Typ, Name, Stadt — mehr brauchen wir nicht, um loszulegen.</p></div>
        <div class="s-card"><span class="num">SCHRITT 02</span><h3>Entwurf in 48 Stunden</h3><p>Du siehst einen echten Entwurf deiner neuen Studio-Website. Kostenlos.</p></div>
        <div class="s-card"><span class="num">SCHRITT 03</span><h3>Live in wenigen Tagen</h3><p>Gefällt er dir, wählst du dein Paket ab 99 €/Monat — 0 € Startkosten.</p></div>
      </div>
    </div>
  </section>

  <section class="tight">
    <div class="wrap">
      <div class="rv">
        <p class="eyebrow">Häufige Fragen von Studiobetreibern</p>
        <h2 class="display">Kurz beantwortet.</h2>
        <div class="faq">
          <details>
            <summary>Können sich Mitglieder über die Website zum Probetraining anmelden?</summary>
            <p>Ja — das ist das Herzstück. Anfragen landen direkt in deinem E-Mail-Postfach, mit Name, Wunschtermin und Trainingsziel. Auf Wunsch verlinken wir auch dein bestehendes Buchungs- oder Mitgliedersystem.</p>
          </details>
          <details>
            <summary>Wie halte ich Kursplan und Preise aktuell?</summary>
            <p>Du schickst uns Änderungen kurz per E-Mail oder WhatsApp — wir pflegen sie ein, meist noch am selben Tag. Das ist in deinem Monatspaket enthalten.</p>
          </details>
          <details>
            <summary>Wir haben schon viele Follower auf Instagram — reicht das nicht?</summary>
            <p>Instagram erreicht die, die dich schon kennen. Google erreicht die, die gerade ein Studio suchen — das sind deine neuen Mitglieder. Die Website verbindet beides: Wir binden deinen Feed ein und machen aus Reichweite Anmeldungen.</p>
          </details>
          <details>
            <summary>Was kostet das?</summary>
            <p>Feste Pakete ab 99 € im Monat mit 0 € Startkosten — alle Details findest du auf der <a href="/#preise">Startseite unter Preise</a>. Vorher siehst du immer erst deinen kostenlosen Entwurf.</p>
          </details>
        </div>
      </div>
    </div>
  </section>

  <div class="cta-band" id="cta">
    <div class="wrap rv">
      <h2 class="display">Sichere dir deinen kostenlosen Website-Entwurf für dein Studio in {city.name}.</h2>
      <p>60 Sekunden Formular — in 48 Stunden siehst du, wie deine neue Studio-Website aussehen könnte. Kostenlos und unverbindlich.</p>
      <a class="btn big" href="/#formular">Jetzt kostenlosen Entwurf anfordern →</a>
    </div>
  </div>

  <footer class="site">
    <div class="wrap">
      <a class="brand" href="/"><img src="/img/logo.png" alt="KMU-Webseiten.de" /></a>
      <nav>
        <a href="/branchen/">Branchen</a>
        <a href="/impressum/">Impressum</a>
        <a href="/datenschutz/">Datenschutz</a>
        <a href="/agb/">AGB</a>
      </nav>
    </div>
  </footer>

  <script is:inline src="/js/reveal.js" defer></script>
</Base>
