---
import Base from '../../layouts/Base.astro';
import { homepageCities } from '../../data/homepage-cities.js';

export function getStaticPaths() {
  return homepageCities.map((city) => ({ params: { slug: city.slug }, props: { city } }));
}

const { city } = Astro.props;
const title = `Homepage erstellen lassen in ${city.name} — Entwurf in 48h, kostenlos | KMU-Webseiten.de`;
const description = `Homepage für deinen Betrieb in ${city.name} erstellen lassen: ohne Technik-Stress, ohne Vorkasse — erst der kostenlose Entwurf, dann deine Entscheidung. Ab 99 €/Monat inkl. Pflege.`;
const canonical = `https://kmu-webseiten.de/homepage-erstellen-lassen/${city.slug}/`;

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: `Homepage erstellen lassen in ${city.name}`,
  description,
  url: canonical,
  provider: {
    '@type': 'ProfessionalService',
    name: 'KMU-Webseiten.de (Pixel56)',
    url: 'https://kmu-webseiten.de/',
  },
  areaServed: { '@type': 'City', name: city.name },
});
---
<Base title={title} description={description} css="/css/city.css" canonical={canonical}>
  <script slot="head" is:inline type="application/ld+json" set:html={jsonLd} />

  <header class="site">
    <div class="wrap">
      <a class="brand" href="/"><img src="/img/logo.png" alt="KMU-Webseiten.de Logo" /></a>
      <a class="btn btn-header" href="/#formular">Kostenlosen Entwurf sichern</a>
    </div>
  </header>

  <div class="hero">
    <div class="wrap">
      <nav class="crumbs" aria-label="Brotkrumen">
        <a href="/">Startseite</a> › <a href="/homepage-erstellen-lassen/" style="color:var(--hero-muted)">Homepage erstellen lassen</a> › <strong style="color:var(--hero-text)">{city.name}</strong>
      </nav>
      <h1 class="display">
        Homepage erstellen lassen in <em>{city.name}</em> — ohne Technik-Stress, ohne Risiko.
      </h1>
      <p class="sub">
        Du erzählst uns von deinem Betrieb, wir bauen deine Homepage — und du
        siehst sie fertig, bevor du dich entscheidest. Pflege danach inklusive.
        Erster Entwurf kostenlos, in 48 Stunden.
      </p>
      <div class="cta-row">
        <a class="btn" href="/#formular">Kostenlosen Entwurf anfordern →</a>
        <span class="mini">100 % kostenlos · Antwort in 48 h</span>
      </div>
    </div>
  </div>

  <section>
    <div class="wrap">
      <div class="rv">
        <p class="eyebrow">Homepage erstellen lassen {city.name}</p>
        <h2 class="display">Die eigene Homepage muss kein Projekt sein. Nur eine Entscheidung.</h2>
        <div class="prose">
          <p>Ob erste <strong>Homepage</strong> überhaupt oder Ablösung eines alten Baukastens in {city.name} — bei uns läuft es umgekehrt als üblich: Erst bauen wir, dann entscheidest du. Du siehst deinen fertigen Entwurf, bevor ein einziger Euro fließt.</p>
          <p>{city.intro}</p>
          <p>{city.pain}</p>
          <p>
            Egal ob du nach <strong>„{city.searchTerms[0]}"</strong>,
            <strong>„{city.searchTerms[1]}"</strong> oder <strong>„{city.searchTerms[2]}"</strong>
            gesucht hast — am Ende willst du dasselbe wie alle: eine Homepage, die gut aussieht,
            gefunden wird und keine Arbeit macht. Genau das ist unser Versprechen.
          </p>
        </div>
      </div>

      <div class="grid2 rv">
        <div class="g-card"><h3><span class="ic">✓</span>Null Technik-Wissen nötig</h3><p>Domain, Hosting, SSL, E-Mail — wir richten alles ein und erklären dir nur das, was du wirklich wissen willst.</p></div>
        <div class="g-card"><h3><span class="ic">✓</span>Individuell statt Baukasten</h3><p>Deine Homepage wird für deinen Betrieb gestaltet und getextet — kein Template, das man an jeder Ecke wiedererkennt.</p></div>
        <div class="g-card"><h3><span class="ic">✓</span>Pflege dauerhaft inklusive</h3><p>Neue Öffnungszeiten, neues Team-Foto, neue Leistung? Kurze Nachricht an uns genügt — du musst nie selbst an die Seite.</p></div>
        <div class="g-card"><h3><span class="ic">✓</span>Gefunden in {city.name}</h3><p>Lokale Suchmaschinen-Optimierung gehört bei uns zum Standard — damit deine Homepage nicht nur existiert, sondern arbeitet.</p></div>
      </div>

      <div class="localbox rv">
        <span class="pin">🏠 Für Betriebe, die es unkompliziert wollen</span>
        <h3 class="display">Der einfachste Weg zur eigenen Homepage.</h3>
        <p>60 Sekunden Formular, 48 Stunden Wartezeit, fertiger Entwurf — dann entscheidest du in Ruhe. Kein Verkaufsgespräch, keine Vorkasse, kein Kleingedrucktes. So sollte sich der Weg zur eigenen Homepage anfühlen.</p>
      </div>
    </div>
  </section>

  <section class="tight">
    <div class="wrap">
      <div class="rv">
        <p class="eyebrow">So einfach geht's</p>
        <h2 class="display">In 3 Schritten zu deiner Homepage für {city.name}.</h2>
      </div>
      <div class="steps-inline rv">
        <div class="s-card"><span class="num">SCHRITT 01</span><h3>60 Sekunden Formular</h3><p>Betrieb, Branche, Stadt — mehr brauchen wir nicht, um loszulegen.</p></div>
        <div class="s-card"><span class="num">SCHRITT 02</span><h3>Entwurf in 48 Stunden</h3><p>Du siehst deine fertige Homepage als echten Entwurf. Kostenlos.</p></div>
        <div class="s-card"><span class="num">SCHRITT 03</span><h3>Live in wenigen Tagen</h3><p>Gefällt sie dir, wählst du dein Paket ab 99 €/Monat — 0 € Startkosten.</p></div>
      </div>
    </div>
  </section>

  <section class="tight">
    <div class="wrap">
      <div class="rv">
        <p class="eyebrow">Häufige Fragen zur Homepage</p>
        <h2 class="display">Kurz beantwortet.</h2>
        <div class="faq">
          <details>
            <summary>Ich hatte noch nie eine Homepage — wie viel muss ich vorbereiten?</summary>
            <p>Fast nichts: Name, Branche und Kontaktdaten reichen für den Entwurf. Alles Weitere — Texte, Struktur, Design — übernehmen wir und stimmen es danach mit dir ab. Fotos und Logo lieferst du einfach nach, wenn du sie hast.</p>
          </details>
          <details>
            <summary>Was ist mit meiner alten Baukasten-Seite (Jimdo, Wix & Co.)?</summary>
            <p>Die lösen wir sauber ab: Inhalte übernehmen, Domain umziehen, nichts geht verloren. Danach hast du eine schnellere, professionellere Homepage — und mehr Zeit, weil wir die Pflege übernehmen.</p>
          </details>
          <details>
            <summary>Gehört mir die Domain? Was passiert bei Kündigung?</summary>
            <p>Die Domain gehört dir, und sie geht bei einem Wechsel selbstverständlich mit. Wir arbeiten mit fairen Konditionen statt mit Abhängigkeiten — Details stehen transparent in unseren <a href="/agb/">AGB</a>.</p>
          </details>
          <details>
            <summary>Was kostet das?</summary>
            <p>Feste Pakete ab 99 € im Monat mit 0 € Startkosten — inklusive Hosting, Domain, SSL, Pflege und Änderungen. Alle Details findest du auf der <a href="/#preise">Startseite unter Preise</a>. Vorher siehst du immer erst deinen kostenlosen Entwurf.</p>
          </details>
        </div>
      </div>
    </div>
  </section>

  <div class="cta-band" id="cta">
    <div class="wrap rv">
      <h2 class="display">Sichere dir deinen kostenlosen Homepage-Entwurf für {city.name}.</h2>
      <p>60 Sekunden Formular — in 48 Stunden siehst du, wie deine neue Homepage aussehen könnte. Kostenlos und unverbindlich.</p>
      <a class="btn big" href="/#formular">Jetzt kostenlosen Entwurf anfordern →</a>
    </div>
  </div>

  <footer class="site">
    <div class="wrap">
      <a class="brand" href="/"><img src="/img/logo.png" alt="KMU-Webseiten.de" /></a>
      <nav>
        <a href="/branchen/">Branchen</a>
        <a href="/impressum/">Impressum</a>
        <a href="/datenschutz/">Datenschutz</a>
        <a href="/agb/">AGB</a>
      </nav>
    </div>
  </footer>

  <script is:inline src="/js/reveal.js" defer></script>
</Base>
