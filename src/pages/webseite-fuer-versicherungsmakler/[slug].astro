---
import Base from '../../layouts/Base.astro';
import { versicherungCities } from '../../data/versicherung-cities.js';

export function getStaticPaths() {
  return versicherungCities.map((city) => ({ params: { slug: city.slug }, props: { city } }));
}

const { city } = Astro.props;
const title = `Webseite für Versicherungsmakler in ${city.name} — Entwurf in 48h | KMU-Webseiten.de`;
const description = `Website für dich als Versicherungsmakler in ${city.name}: Unabhängigkeit sichtbar machen, Erstgespräche gewinnen — gegen Portale und Strukturvertriebe. Kostenloser Entwurf in 48 Stunden, ab 99 €/Monat.`;
const canonical = `https://kmu-webseiten.de/webseite-fuer-versicherungsmakler/${city.slug}/`;

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: `Webseite für Versicherungsmakler in ${city.name}`,
  description,
  url: canonical,
  provider: {
    '@type': 'ProfessionalService',
    name: 'KMU-Webseiten.de (Pixel56)',
    url: 'https://kmu-webseiten.de/',
  },
  areaServed: { '@type': 'City', name: city.name },
  audience: { '@type': 'Audience', audienceType: 'Versicherungsmakler & Finanzberater' },
});
---
<Base title={title} description={description} css="/css/city.css" canonical={canonical}>
  <script slot="head" is:inline type="application/ld+json" set:html={jsonLd} />

  <header class="site">
    <div class="wrap">
      <a class="brand" href="/"><img src="/img/logo.png" alt="KMU-Webseiten.de Logo" /></a>
      <a class="btn btn-header" href="/#formular">Kostenlosen Entwurf sichern</a>
    </div>
  </header>

  <div class="hero">
    <div class="wrap">
      <nav class="crumbs" aria-label="Brotkrumen">
        <a href="/">Startseite</a> › <a href="/webseite-fuer-versicherungsmakler/" style="color:var(--hero-muted)">Webseite für Versicherungsmakler</a> › <strong style="color:var(--hero-text)">{city.name}</strong>
      </nav>
      <h1 class="display">
        Kunden in <em>{city.name}</em> sind portalmüde — und suchen einen echten Berater.
      </h1>
      <p class="sub">
        Eine Website, die deine Unabhängigkeit und Beratungsqualität sichtbar macht —
        und aus Vergleichs-Frustrierten deine Mandanten macht.
        Erster Entwurf kostenlos, in 48 Stunden.
      </p>
      <div class="cta-row">
        <a class="btn" href="/#formular">Kostenlosen Entwurf anfordern →</a>
        <span class="mini">100 % kostenlos · Antwort in 48 h</span>
      </div>
    </div>
  </div>

  <section>
    <div class="wrap">
      <div class="rv">
        <p class="eyebrow">Webseite für Versicherungsmakler {city.name}</p>
        <h2 class="display">Das Portal vergleicht Preise. Du verstehst Menschen.</h2>
        <div class="prose">
          <p>Ob <strong>Berufsunfähigkeit</strong>, <strong>Altersvorsorge</strong> oder <strong>Gewerbeversicherung</strong> in {city.name} — bei existenziellen Themen wollen Menschen keinen Tarifrechner, sondern jemanden, der zuhört, erklärt und auf ihrer Seite steht. Genau dafür gibt es dich als unabhängigen Makler.</p>
          <p>{city.intro}</p>
          <p>{city.pain}</p>
          <p>
            Egal ob nach <strong>„{city.searchTerms[0]}"</strong>,
            <strong>„{city.searchTerms[1]}"</strong> oder <strong>„{city.searchTerms[2]}"</strong>
            gesucht wird — der Weg zum Erstgespräch führt über deinen Auftritt: Wer dort
            Unabhängigkeit, Qualifikation und Menschlichkeit erkennt, ruft an. Wer nichts
            findet, landet wieder beim Portal.
          </p>
        </div>
      </div>

      <div class="grid2 rv">
        <div class="g-card"><h3><span class="ic">✓</span>Unabhängigkeit als roter Faden</h3><p>Makler statt Vertreter: Wir machen den Unterschied verständlich — dein stärkstes Argument gegen Strukturvertrieb und Portal.</p></div>
        <div class="g-card"><h3><span class="ic">✓</span>Erstgespräch als klares Ziel</h3><p>Terminanfrage oder Kalender-Buchung auf jeder Seite — die Hürde zum ersten Gespräch so niedrig wie möglich.</p></div>
        <div class="g-card"><h3><span class="ic">✓</span>Themen-Seiten für deine Schwerpunkte</h3><p>BU, PKV, bAV, Gewerbe: Jeder Schwerpunkt einzeln auffindbar und verständlich erklärt — ohne Fachchinesisch, ohne Verkaufsdruck.</p></div>
        <div class="g-card"><h3><span class="ic">✓</span>Seriös &amp; rechtssicher</h3><p>Erstinformation, Vermittlerregister, Impressumspflichten — wir setzen die formalen Anforderungen an Makler-Websites sauber um.</p></div>
      </div>

      <div class="localbox rv">
        <span class="pin">🛡️ Für Makler, deren Zeit in Beratung gehört</span>
        <h3 class="display">Du berätst deine Kunden. Wir positionieren dich.</h3>
        <p>Du nennst uns deine Schwerpunkte und deine Beratungsphilosophie — wir liefern in 48 Stunden einen Entwurf, der Vertrauen aufbaut und Erstgespräche bringt. Sachlich, persönlich und ohne die üblichen Versicherungs-Floskeln.</p>
      </div>
    </div>
  </section>

  <section class="tight">
    <div class="wrap">
      <div class="rv">
        <p class="eyebrow">So einfach geht's</p>
        <h2 class="display">In 3 Schritten zur neuen Makler-Website in {city.name}.</h2>
      </div>
      <div class="steps-inline rv">
        <div class="s-card"><span class="num">SCHRITT 01</span><h3>60 Sekunden Formular</h3><p>Schwerpunkte, Name, Stadt — mehr brauchen wir nicht, um loszulegen.</p></div>
        <div class="s-card"><span class="num">SCHRITT 02</span><h3>Entwurf in 48 Stunden</h3><p>Du siehst einen echten Entwurf deiner neuen Website. Kostenlos.</p></div>
        <div class="s-card"><span class="num">SCHRITT 03</span><h3>Live in wenigen Tagen</h3><p>Gefällt er dir, wählst du dein Paket ab 99 €/Monat — 0 € Startkosten.</p></div>
      </div>
    </div>
  </section>

  <section class="tight">
    <div class="wrap">
      <div class="rv">
        <p class="eyebrow">Häufige Fragen von Maklern</p>
        <h2 class="display">Kurz beantwortet.</h2>
        <div class="faq">
          <details>
            <summary>Welche Pflichtangaben gehören auf eine Makler-Website?</summary>
            <p>Neben dem üblichen Impressum u. a. die Angaben nach § 15 VersVermV: Vermittlerregister-Nummer, Erlaubnis nach § 34d GewO, zuständige Behörde. Wir setzen das strukturiert um — die inhaltliche Prüfung deiner Pflichtangaben bleibt bei dir bzw. deinem Verband.</p>
          </details>
          <details>
            <summary>Kann ich eine Online-Terminbuchung einbinden?</summary>
            <p>Ja — Calendly, Microsoft Bookings oder das Tool deiner Wahl binden wir prominent ein. Gerade jüngere Kunden buchen ihr Erstgespräch lieber selbst als anzurufen.</p>
          </details>
          <details>
            <summary>Wie hebe ich mich von Check24 &amp; Co. ab?</summary>
            <p>Nicht über den Preis, sondern über das, was Portale nicht können: persönliche Analyse, Leistungsfall-Begleitung, langfristige Betreuung. Deine Website erzählt genau diese Geschichte — mit dir als Person im Mittelpunkt statt einem Tarifrechner.</p>
          </details>
          <details>
            <summary>Was kostet das?</summary>
            <p>Feste Pakete ab 99 € im Monat mit 0 € Startkosten — alle Details findest du auf der <a href="/#preise">Startseite unter Preise</a>. Vorher siehst du immer erst deinen kostenlosen Entwurf. Ein einziger vermittelter BU-Vertrag refinanziert das Paket um ein Vielfaches.</p>
          </details>
        </div>
      </div>
    </div>
  </section>

  <div class="cta-band" id="cta">
    <div class="wrap rv">
      <h2 class="display">Sichere dir deinen kostenlosen Website-Entwurf für deine Beratung in {city.name}.</h2>
      <p>60 Sekunden Formular — in 48 Stunden siehst du, wie dein neuer Auftritt aussehen könnte. Kostenlos und unverbindlich.</p>
      <a class="btn big" href="/#formular">Jetzt kostenlosen Entwurf anfordern →</a>
    </div>
  </div>

  <footer class="site">
    <div class="wrap">
      <a class="brand" href="/"><img src="/img/logo.png" alt="KMU-Webseiten.de" /></a>
      <nav>
        <a href="/branchen/">Branchen</a>
        <a href="/impressum/">Impressum</a>
        <a href="/datenschutz/">Datenschutz</a>
        <a href="/agb/">AGB</a>
      </nav>
    </div>
  </footer>

  <script is:inline src="/js/reveal.js" defer></script>
</Base>
