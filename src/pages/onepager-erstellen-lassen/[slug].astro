---
import Base from '../../layouts/Base.astro';
import { onepagerCities } from '../../data/onepager-cities.js';

export function getStaticPaths() {
  return onepagerCities.map((city) => ({ params: { slug: city.slug }, props: { city } }));
}

const { city } = Astro.props;
const title = `One-Pager & Einseiter erstellen lassen in ${city.name} — Entwurf in 48h | KMU-Webseiten.de`;
const description = `Kompakte Einseiter-Website für deinen Betrieb in ${city.name}: alles Wichtige auf einer Seite — professionell, auffindbar, bezahlbar. Kostenloser Entwurf in 48 Stunden, ab 99 €/Monat.`;
const canonical = `https://kmu-webseiten.de/onepager-erstellen-lassen/${city.slug}/`;

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: `One-Pager erstellen lassen in ${city.name}`,
  description,
  url: canonical,
  provider: {
    '@type': 'ProfessionalService',
    name: 'KMU-Webseiten.de (Pixel56)',
    url: 'https://kmu-webseiten.de/',
  },
  areaServed: { '@type': 'City', name: city.name },
});
---
<Base title={title} description={description} css="/css/city.css" canonical={canonical}>
  <script slot="head" is:inline type="application/ld+json" set:html={jsonLd} />

  <header class="site">
    <div class="wrap">
      <a class="brand" href="/"><img src="/img/logo.png" alt="KMU-Webseiten.de Logo" /></a>
      <a class="btn btn-header" href="/#formular">Kostenlosen Entwurf sichern</a>
    </div>
  </header>

  <div class="hero">
    <div class="wrap">
      <nav class="crumbs" aria-label="Brotkrumen">
        <a href="/">Startseite</a> › <a href="/onepager-erstellen-lassen/" style="color:var(--hero-muted)">One-Pager erstellen lassen</a> › <strong style="color:var(--hero-text)">{city.name}</strong>
      </nav>
      <h1 class="display">
        Ein Einseiter für <em>{city.name}</em>: alles Wichtige, eine Seite, null Aufwand für dich.
      </h1>
      <p class="sub">
        Die kompakte Website für kleine Betriebe und Selbstständige — Leistungen,
        Kontakt, Öffnungszeiten und Impressum, professionell auf einer Seite.
        Erster Entwurf kostenlos, in 48 Stunden.
      </p>
      <div class="cta-row">
        <a class="btn" href="/#formular">Kostenlosen Entwurf anfordern →</a>
        <span class="mini">100 % kostenlos · Antwort in 48 h</span>
      </div>
    </div>
  </div>

  <section>
    <div class="wrap">
      <div class="rv">
        <p class="eyebrow">One-Pager &amp; Einseiter {city.name}</p>
        <h2 class="display">Nicht jeder braucht zehn Unterseiten. Jeder braucht einen guten Auftritt.</h2>
        <div class="prose">
          <p>Ein <strong>One-Pager</strong> (auch <strong>Einseiter</strong> oder <strong>Portfolioseite</strong>) bringt deinen Betrieb auf den Punkt: Wer du bist, was du anbietest, wie man dich erreicht — hochwertig gestaltet, bei Google auffindbar und rechtssicher mit Impressum und Datenschutz.</p>
          <p>{city.intro}</p>
          <p>{city.pain}</p>
          <p>
            Egal ob du nach <strong>„{city.searchTerms[0]}"</strong>,
            <strong>„{city.searchTerms[1]}"</strong> oder <strong>„{city.searchTerms[2]}"</strong>
            gesucht hast — entscheidend ist nicht die Seitenzahl, sondern der Eindruck:
            Ein durchdachter Einseiter wirkt professioneller als jede halbfertige große Website.
          </p>
        </div>
      </div>

      <div class="grid2 rv">
        <div class="g-card"><h3><span class="ic">✓</span>Alles Wichtige auf einen Blick</h3><p>Leistungen, Über-mich, Kontakt, Öffnungszeiten, Anfahrt — klar strukturiert, ohne dass Besucher suchen müssen.</p></div>
        <div class="g-card"><h3><span class="ic">✓</span>Bei Google präsent</h3><p>Auch ein Einseiter wird lokal optimiert — damit dich Kunden in {city.name} finden, wenn sie nach deiner Leistung suchen.</p></div>
        <div class="g-card"><h3><span class="ic">✓</span>Rechtssicher &amp; komplett</h3><p>Impressum, Datenschutz, SSL, eigene Domain und E-Mail-Weiterleitung — die Pflichten sind erledigt, bevor du danach fragen musst.</p></div>
        <div class="g-card"><h3><span class="ic">✓</span>Wächst mit, wenn du wächst</h3><p>Aus dem Einseiter wird bei Bedarf jederzeit eine größere Website — ohne Neuanfang, dein Auftritt wächst einfach mit.</p></div>
      </div>

      <div class="localbox rv">
        <span class="pin">📄 Für alle, die einfach professionell online sein wollen</span>
        <h3 class="display">Du machst deinen Job. Deine Seite macht ihren.</h3>
        <p>Du beantwortest ein kurzes Formular — wir liefern in 48 Stunden deinen fertigen Einseiter-Entwurf: individuell gestaltet, mit echten Texten statt Platzhaltern. Danach kümmern wir uns dauerhaft um Technik und Änderungen.</p>
      </div>
    </div>
  </section>

  <section class="tight">
    <div class="wrap">
      <div class="rv">
        <p class="eyebrow">So einfach geht's</p>
        <h2 class="display">In 3 Schritten zu deinem One-Pager für {city.name}.</h2>
      </div>
      <div class="steps-inline rv">
        <div class="s-card"><span class="num">SCHRITT 01</span><h3>60 Sekunden Formular</h3><p>Betrieb, Leistung, Stadt — mehr brauchen wir nicht, um loszulegen.</p></div>
        <div class="s-card"><span class="num">SCHRITT 02</span><h3>Entwurf in 48 Stunden</h3><p>Du siehst deinen fertigen Einseiter als echten Entwurf. Kostenlos.</p></div>
        <div class="s-card"><span class="num">SCHRITT 03</span><h3>Live in wenigen Tagen</h3><p>Gefällt er dir, wählst du dein Paket ab 99 €/Monat — 0 € Startkosten.</p></div>
      </div>
    </div>
  </section>

  <section class="tight">
    <div class="wrap">
      <div class="rv">
        <p class="eyebrow">Häufige Fragen zum One-Pager</p>
        <h2 class="display">Kurz beantwortet.</h2>
        <div class="faq">
          <details>
            <summary>Reicht eine einzige Seite wirklich für meinen Betrieb?</summary>
            <p>Für die meisten kleinen Betriebe und Selbstständigen: ja. Kunden wollen wissen, was du machst, ob du gut bist und wie sie dich erreichen — das leistet ein Einseiter perfekt. Wächst dein Bedarf, bauen wir die Seite einfach aus.</p>
          </details>
          <details>
            <summary>Wird ein One-Pager bei Google gefunden?</summary>
            <p>Ja — wir optimieren ihn auf deine Leistung und deine Stadt, mit sauberer Technik und strukturierten Daten. Für lokale Suchen („…in der Nähe") ist ein gepflegter Einseiter oft stärker als eine vernachlässigte große Website.</p>
          </details>
          <details>
            <summary>Eignet sich das auch als Portfolioseite?</summary>
            <p>Sehr gut sogar: Für Kreative, Berater und Freiberufler bauen wir den Einseiter als Portfolio — mit Arbeitsproben, Werdegang und Kontakt. Deine professionelle Adresse im Netz, unabhängig von Social-Media-Plattformen.</p>
          </details>
          <details>
            <summary>Was kostet das?</summary>
            <p>Feste Pakete ab 99 € im Monat mit 0 € Startkosten — alle Details findest du auf der <a href="/#preise">Startseite unter Preise</a>. Vorher siehst du immer erst deinen kostenlosen Entwurf.</p>
          </details>
        </div>
      </div>
    </div>
  </section>

  <div class="cta-band" id="cta">
    <div class="wrap rv">
      <h2 class="display">Sichere dir deinen kostenlosen One-Pager-Entwurf für {city.name}.</h2>
      <p>60 Sekunden Formular — in 48 Stunden siehst du, wie dein Einseiter aussehen könnte. Kostenlos und unverbindlich.</p>
      <a class="btn big" href="/#formular">Jetzt kostenlosen Entwurf anfordern →</a>
    </div>
  </div>

  <footer class="site">
    <div class="wrap">
      <a class="brand" href="/"><img src="/img/logo.png" alt="KMU-Webseiten.de" /></a>
      <nav>
        <a href="/branchen/">Branchen</a>
        <a href="/impressum/">Impressum</a>
        <a href="/datenschutz/">Datenschutz</a>
        <a href="/agb/">AGB</a>
      </nav>
    </div>
  </footer>

  <script is:inline src="/js/reveal.js" defer></script>
</Base>
